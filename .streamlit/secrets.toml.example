# ── WCSAA Scoring App — Streamlit Secrets Template ───────────────────────────
# Copy this file to secrets.toml for local dev, or paste into the
# Streamlit Cloud app's Secrets tab (Settings → Secrets).
#
# PRODUCTION app:  APP_ENV = "production"   (or omit — defaults to production)
# STAGING app:     APP_ENV = "staging"
# ─────────────────────────────────────────────────────────────────────────────

# Environment identifier — controls sidebar badge and env-gating
APP_ENV = "staging"   # change to "production" for the live app

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project URL from: Supabase Dashboard → Settings → API → Project URL
SUPABASE_URL = "https://<project-ref>.supabase.co"

# Service role key from: Supabase Dashboard → Settings → API → service_role
# (Recommended — bypasses RLS for server-side use)
# If using the anon/publishable key (sb_publishable_...), ensure RLS is disabled.
SUPABASE_KEY = "sb_secret_..."

# ── Authentication ────────────────────────────────────────────────────────────
# Add one [auth.users.*] block per user.
# role must be "admin" or "viewer"

[auth.users.admin]
username = "admin"
password = "change-me"
role     = "admin"

[auth.users.viewer1]
username = "viewer"
password = "change-me"
role     = "viewer"
