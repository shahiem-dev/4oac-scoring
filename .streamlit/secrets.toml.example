# ── WCSAA Scoring App — Streamlit Secrets Template ──────────────────────
# Copy this file to secrets.toml for local dev, or paste into the
# Streamlit Cloud app's Secrets tab (Settings → Secrets).
#
# PRODUCTION app:  APP_ENV = "production"   (or omit — defaults to production)
# STAGING app:     APP_ENV = "staging"
# ─────────────────────────────────────────────────────────────────────────

# Environment identifier — controls sidebar badge and future env-gating
APP_ENV = "staging"   # change to "production" for the live app

# ── Authentication ────────────────────────────────────────────────────────
# Add one [[auth.users.*]] block per user.
# role must be "admin" or "viewer"

[auth.users.admin]
username = "admin"
password = "change-me"
role     = "admin"

[auth.users.viewer1]
username = "viewer"
password = "change-me"
role     = "viewer"
